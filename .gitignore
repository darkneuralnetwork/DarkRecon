# ── Compiled binaries ──
/dark-recon
/server
*.exe
/bin/

# ── Debian package build output (regenerated by dist/build-deb.sh) ──
/dist/staging/
/dist/*.deb

# ── Go build/test artifacts ──
*.test
*.out
coverage.txt

# ── SQLite databases (per-target scan data) ──
*.db
*.db-wal
*.db-shm

# ── Scan output ──
/dark_recon_results/

# ── Logs ──
*.log

# ── Python ──
__pycache__/
*.pyc
*.pyo
*.egg-info/
.venv/
venv/

# ── Editor / OS ──
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# ── Secrets / local config ──
